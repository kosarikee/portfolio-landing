# ============================================================
# Environment variables — скопируйте в .env и заполните
# ============================================================

# Telegram Bot Token (от BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID чата, куда бот будет присылать заявки
TELEGRAM_CHAT_ID=your_chat_id_here

# Публичный email (отображается на сайте в футере)
NEXT_PUBLIC_EMAIL=your@email.com

# Домен для SSL (если есть, опционально)
DOMAIN=your-domain.ru
